# Local server port
PORT=4173

# Provider order. Options: sarvam, gemini, openrouter, mymemory
TRANSLATION_PROVIDER_ORDER=sarvam,gemini,openrouter,mymemory

# Sarvam (starts with free credits)
# SARVAM_API_KEY=
# SARVAM_MODEL=sarvam-translate:v1
# SARVAM_CHAT_MODEL=sarvam-30b

# Gemini (AI Studio free tier available with rate limits)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# OpenRouter (can use free models if available)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free

# Optional: improves MyMemory free quota behavior
# MYMEMORY_CONTACT_EMAIL=you@example.com
